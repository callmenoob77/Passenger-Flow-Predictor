# ─── Supabase (optional — app runs in demo mode without it) ───────────────────
# PostgreSQL connection string from your Supabase project settings > Database
SUPABASE_CONN_STRING=

# Supabase REST API (needed by ML service for email notifications)
SUPABASE_URL=
SUPABASE_KEY=

# ─── Email (optional — notifications disabled without it) ─────────────────────
# Free key from https://resend.com. With RESEND_API_KEY + SUPABASE_CONN_STRING
# set, the rerouting API emails each subscriber once, ALERT_LEAD_H hours before
# their flight departs, if the flight is cancelled/delayed or fog risk fires.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
# ALERT_LEAD_H=2     # email this many hours before departure
# NOTIFY_POLL_S=300  # how often the notifier checks subscriptions (seconds)

# ─── External APIs (optional) ─────────────────────────────────────────────────
# Iași departures are looked up live on the airport's own board API by default
# (free, no key). Uncomment and leave empty to disable it:
# LRIA_BOARD_URL=

# AviationStack adds live lookup for non-Iași flights. Free key:
# https://aviationstack.com/signup/free (~100 requests/month; cached 10 min).
AVIATIONSTACK_API_KEY=

# ─── Service URLs ─────────────────────────────────────────────────────────────
# URL of the ML service (used by rerouting API to get fog risk)
ML_API_URL=http://localhost:8001

# ─── CORS (comma-separated, for production backend deploy) ────────────────────
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
